# LLM (LiteLLM proxy)
LITELLM_BASE_URL=https://litellm.example.internal
LITELLM_API_KEY=changeme
LITELLM_CHAT_MODEL=claude-opus-4-7
LITELLM_EMBEDDING_MODEL=text-embedding-3-large

# GitHub
GITHUB_REPO_URL=https://github.com/example/architecture
GITHUB_TOKEN=changeme

# Indexer
INDEXER_INTERVAL_HOURS=4

# Web search
WEB_SEARCH_BACKEND=noop
WEB_SEARCH_ALLOWED_DOMAINS=learn.microsoft.com,docs.microsoft.com,nist.gov,cisa.gov

# App
ADMIN_TOKEN=changeme-admin-token
RATE_LIMIT_PER_MIN=30
DATA_DIR=/data
PORT=8080
SESSION_SECRET=changeme-32-bytes-random
